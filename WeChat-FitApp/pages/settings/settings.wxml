<view class="page"><text class="title">设置</text><view class="settings-list"><view class="setting-item"><text class="label">语言</text><picker bindchange="onLanguageChange" value="{{langIndex}}" range="{{languages}}"><view class="picker-value">{{languages[langIndex]}}</view></picker></view><view class="setting-item"><text class="label">声音效果</text><switch checked="{{soundEnabled}}" bindchange="onSoundChange"></switch></view><view class="setting-item"><text class="label">振动反馈</text><switch checked="{{vibrationEnabled}}" bindchange="onVibrationChange"></switch></view></view><view class="info"><text>FitApp v1.0.0</text><text>离线健身训练助手</text></view></view>