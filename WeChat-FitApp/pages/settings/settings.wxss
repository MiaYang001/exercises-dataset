.page{padding:16rpx}.title{display:block;font-size:36rpx;font-weight:bold;margin-bottom:24rpx}.settings-list{background:#fff;border-radius:8rpx;overflow:hidden}.setting-item{display:flex;justify-content:space-between;align-items:center;padding:16rpx;border-bottom:1rpx solid #eee}.setting-item:last-child{border-bottom:none}.label{font-size:28rpx;color:#262626}.picker-value{color:#1E90FF;font-size:26rpx}switch{transform:scale(0.8)}.info{display:flex;flex-direction:column;align-items:center;gap:8rpx;margin-top:60rpx;color:#999;font-size:24rpx}