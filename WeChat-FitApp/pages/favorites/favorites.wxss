.page{padding:16rpx}.title{display:block;font-size:36rpx;font-weight:bold;margin-bottom:16rpx}.favorites-list{height:100vh}.empty{display:flex;align-items:center;justify-content:center;height:400rpx;color:#999}.fav-item{padding:16rpx;margin-bottom:12rpx}.fav-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.fav-name{font-size:30rpx;font-weight:bold;flex:1}.btn-remove{background:#F5222D;color:#fff;border:none;border-radius:50%;width:40rpx;height:40rpx;padding:0;font-size:24rpx}.fav-info{display:flex;gap:8rpx}.tag{display:inline-block;background:#E8F4FF;color:#1E90FF;padding:4rpx 12rpx;border-radius:12rpx;font-size:22rpx}