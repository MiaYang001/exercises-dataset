<view class="page"><text class="title">收藏夹</text><scroll-view class="favorites-list" scroll-y wx:if="{{favorites.length>0}}"><block wx:for="{{favorites}}" wx:key="id"><view class="fav-item card" bindtap="goDetail" data-id="{{item.id}}"><view class="fav-header"><text class="fav-name">{{item.name}}</text><button class="btn-remove" bindtap="removeFav" data-id="{{item.id}}" catchTap="true">✕</button></view><view class="fav-info"><text class="tag">{{item.body_part}}</text><text class="tag">{{item.equipment}}</text></view></view></block></scroll-view><view wx:else class="empty"><text>还没有收藏的练习</text></view></view>