<view class="page"><view class="header"><text class="title">训练计划</text><button class="btn-create" bindtap="showCreatePlan">+ 新建</button></view><scroll-view class="plans-list" scroll-y wx:if="{{plans.length>0}}"><block wx:for="{{plans}}" wx:key="id"><view class="plan-item"><text class="plan-name">{{item.name}}</text><text class="plan-count">{{item.exercises.length}} 个动作</text><view class="plan-actions"><button class="btn-small" bindtap="startTraining" data-id="{{item.id}}" catchTap="true">开始</button><button class="btn-small danger" bindtap="deletePlan" data-id="{{item.id}}" catchTap="true">删除</button></view></view></block></scroll-view><view wx:else class="empty"><text>还没有训练计划</text></view><view class="modal" wx:if="{{showModal}}" bindtap="hideCreatePlan"><view class="modal-content" catchTap="true"><text class="modal-title">创建新计划</text><input class="input" type="text" placeholder="计划名称" bindinput="onPlanNameInput" value="{{planName}}" /><view class="modal-buttons"><button bindtap="hideCreatePlan">取消</button><button class="btn-primary" bindtap="createNewPlan">创建</button></view></view></view></view>