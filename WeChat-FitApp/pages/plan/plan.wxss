.page{display:flex;flex-direction:column;height:100vh}.header{display:flex;justify-content:space-between;align-items:center;padding:16rpx;background:linear-gradient(135deg,#1E90FF,#1873CC);color:#fff}.title{font-size:36rpx;font-weight:bold}.btn-create{background:rgba(255,255,255,0.2);color:#fff;border:2rpx solid #fff;border-radius:4rpx;padding:6rpx 12rpx;font-size:24rpx}.plans-list{flex:1;padding:12rpx}.empty{display:flex;align-items:center;justify-content:center;height:100%;color:#999}.plan-item{background:#fff;border-radius:8rpx;padding:16rpx;margin-bottom:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.1)}.plan-name{display:block;font-size:32rpx;font-weight:bold;margin-bottom:6rpx}.plan-count{display:block;color:#666;font-size:24rpx;margin-bottom:12rpx}.plan-actions{display:flex;gap:8rpx}.btn-small{flex:1;background:#1E90FF;color:#fff;border:none;border-radius:4rpx;padding:8rpx;font-size:24rpx}.btn-small.danger{background:#F5222D}.modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:1000}.modal-content{background:#fff;border-radius:12rpx;padding:24rpx;width:80%}.modal-title{display:block;font-size:32rpx;font-weight:bold;margin-bottom:16rpx}.input{display:block;width:100%;border:1rpx solid #ddd;border-radius:6rpx;padding:12rpx;font-size:28rpx;margin-bottom:16rpx;box-sizing:border-box}.modal-buttons{display:flex;gap:12rpx}.modal-buttons button{flex:1;border:none;border-radius:6rpx;padding:12rpx;font-size:28rpx}.btn-primary{background:#1E90FF;color:#fff}