<view class="page"><view wx:if="{{exercise}}" class="content"><view class="header"><text class="name">{{exercise.name}}</text><button class="btn-fav" bindtap="toggleFav">{{isFav?'★':'☆'}}</button></view><view class="info-grid"><view class="info-item"><text class="label">身体部位</text><text class="value">{{exercise.body_part}}</text></view><view class="info-item"><text class="label">目标肌肉</text><text class="value">{{exercise.target}}</text></view><view class="info-item"><text class="label">器材</text><text class="value">{{exercise.equipment}}</text></view><view class="info-item"><text class="label">辅助肌肉</text><text class="value">{{exercise.muscle_group}}</text></view></view><view class="instructions"><text class="section-title">说明</text><text class="instruction-text">{{exercise.instructions[currentLang]||exercise.instructions.en}}</text></view><button class="btn-add-plan" bindtap="showAddToPlan">添加到计划</button></view><view class="modal" wx:if="{{showModal}}" bindtap="hideModal"><view class="modal-content" catchTap="true"><text class="modal-title">添加到计划</text><picker bindchange="onPlanChange" value="{{selectedPlanIndex}}" range="{{plans}}" range-key="name"><view class="picker-item">{{plans[selectedPlanIndex]?plans[selectedPlanIndex].name:'选择计划'}}</view></picker><view class="sets-config"><view class="config-item"><text>组数:</text><input type="number" value="{{sets}}" bindinput="onSetsInput" /></view><view class="config-item"><text>次数:</text><input type="number" value="{{reps}}" bindinput="onRepsInput" /></view><view class="config-item"><text>重量(kg):</text><input type="number" value="{{weight}}" bindinput="onWeightInput" /></view></view><view class="modal-buttons"><button bindtap="hideModal">取消</button><button class="btn-primary" bindtap="addToPlan">确认</button></view></view></view></view>