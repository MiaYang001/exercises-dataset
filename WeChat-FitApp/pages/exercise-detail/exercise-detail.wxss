.page{padding:0}.content{padding:16rpx}.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24rpx;padding-bottom:16rpx;border-bottom:2rpx solid #eee}.name{display:block;font-size:36rpx;font-weight:bold;flex:1}.btn-fav{background:none;border:none;font-size:36rpx;color:#FFD700;padding:0;width:auto}.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-bottom:24rpx}.info-item{background:#f5f5f5;padding:12rpx;border-radius:8rpx}.label{display:block;font-size:22rpx;color:#666;margin-bottom:4rpx}.value{display:block;font-size:26rpx;color:#262626;font-weight:bold}.instructions{background:#fff;border-radius:8rpx;padding:16rpx;margin-bottom:24rpx}.section-title{display:block;font-size:28rpx;font-weight:bold;margin-bottom:12rpx}.instruction-text{display:block;font-size:26rpx;line-height:1.6;color:#262626}.btn-add-plan{width:100%;background:#1E90FF;color:#fff;border:none;border-radius:8rpx;padding:16rpx;font-size:28rpx}.modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:flex;align-items:flex-end;z-index:1000}.modal-content{background:#fff;border-radius:12rpx 12rpx 0 0;padding:24rpx;width:100%}.modal-title{display:block;font-size:32rpx;font-weight:bold;margin-bottom:16rpx}.picker-item{background:#f5f5f5;border-radius:6rpx;padding:12rpx;font-size:26rpx;margin-bottom:16rpx}.sets-config{display:flex;flex-direction:column;gap:12rpx;margin-bottom:24rpx}.config-item{display:flex;align-items:center;gap:12rpx}.config-item text{min-width:80rpx;font-size:26rpx}.config-item input{flex:1;border:1rpx solid #ddd;border-radius:4rpx;padding:8rpx 12rpx;font-size:26rpx}.modal-buttons{display:flex;gap:12rpx}.modal-buttons button{flex:1;border:none;border-radius:6rpx;padding:12rpx;font-size:26rpx}.btn-primary{background:#1E90FF;color:#fff}