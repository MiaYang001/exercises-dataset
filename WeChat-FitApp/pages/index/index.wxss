.page{display:flex;flex-direction:column;height:100vh}.header{background:linear-gradient(135deg,#1E90FF 0%,#1873CC 100%);padding:16rpx;color:#fff}.title{display:block;font-size:40rpx;font-weight:bold;margin-bottom:16rpx}.search-nav{display:block}.search-bar{background:rgba(255,255,255,0.2);border-radius:20rpx;padding:12rpx 20rpx;border:2rpx solid rgba(255,255,255,0.5)}.placeholder{color:rgba(255,255,255,0.7);font-size:26rpx}.categories{white-space:nowrap;background:#fff;border-bottom:1rpx solid #eee;padding:12rpx 0}.cat-list{display:flex;padding:0 16rpx}.cat-item{display:inline-block;padding:8rpx 20rpx;margin-right:12rpx;border-radius:20rpx;background:#f0f0f0;color:#666;font-size:26rpx}.cat-item.active{background:#1E90FF;color:#fff}.loading{display:flex;align-items:center;justify-content:center;flex:1}.exercises{flex:1;padding:12rpx}.empty{display:flex;align-items:center;justify-content:center;height:400rpx;color:#999}.exercise-item{margin-bottom:12rpx;padding:16rpx;border-radius:8rpx;background:#fff}.ex-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8rpx}.ex-name{font-size:30rpx;font-weight:bold;flex:1}.favorite-icon{font-size:32rpx;color:#ddd}.favorite-icon .filled{color:#FFD700}.ex-tags{display:flex;gap:8rpx;margin-bottom:8rpx}.tag{background:#E8F4FF;color:#1E90FF;padding:4rpx 12rpx;border-radius:12rpx;font-size:22rpx}.ex-target{color:#666;font-size:24rpx}