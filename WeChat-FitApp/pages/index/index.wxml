<view class="page"><view class="header"><text class="title">💪 FitApp</text><navigator url="/pages/search/search" class="search-nav"><view class="search-bar"><text class="placeholder">{{i18n.searchPlaceholder}}</text></view></navigator></view><scroll-view class="categories" scroll-x><view class="cat-list"><block wx:for="{{categories}}" wx:key="id"><view class="cat-item {{activeCategory===item?'active':''}}" bindtap="selectCategory" data-cat="{{item}}">{{item}}</view></block></view></scroll-view><view wx:if="{{loading}}" class="loading"><view class="spinner"></view></view><scroll-view wx:else class="exercises" scroll-y bindscrolltolower="loadMore"><view wx:if="{{exercises.length===0}}" class="empty"><text>{{i18n.noResults}}</text></view><block wx:for="{{exercises}}" wx:key="id"><view class="exercise-item card" bindtap="goDetail" data-id="{{item.id}}"><view class="ex-header"><text class="ex-name">{{item.name}}</text><view class="favorite-icon" bindtap="toggleFav" data-id="{{item.id}}" catchTap="true"><text class="{{isFav(item.id)?'filled':''}}">★</text></view></view><view class="ex-tags"><text class="tag">{{item.body_part}}</text><text class="tag">{{item.equipment}}</text></view><text class="ex-target">{{item.target}}</text></view></block></scroll-view></view>