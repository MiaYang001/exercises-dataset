.page{display:flex;flex-direction:column;height:100vh}.search-header{display:flex;padding:12rpx;background:#fff;gap:8rpx}.search-input{flex:1;border:1rpx solid #ddd;border-radius:6rpx;padding:12rpx 16rpx;font-size:28rpx}.search-btn{background:#1E90FF;color:#fff;border:none;border-radius:6rpx;padding:0 24rpx;font-size:28rpx;height:72rpx}.filters{display:flex;gap:16rpx;padding:12rpx 16rpx;background:#f5f5f5;border-bottom:1rpx solid #eee}.filter-group{flex:1;display:flex;flex-direction:column;gap:6rpx}.filter-label{font-size:22rpx;color:#666}.picker-item{background:#fff;border:1rpx solid #ddd;border-radius:4rpx;padding:8rpx 12rpx;font-size:26rpx}.results{flex:1;overflow-y:auto}.empty{display:flex;align-items:center;justify-content:center;height:300rpx;color:#999}.result-item{padding:16rpx;border-bottom:1rpx solid #eee;background:#fff}.result-name{display:block;font-size:30rpx;font-weight:bold;margin-bottom:6rpx}.result-info{display:block;font-size:24rpx;color:#999}