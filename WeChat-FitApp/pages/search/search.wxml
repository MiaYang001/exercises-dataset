<view class="page"><view class="search-header"><input class="search-input" type="text" placeholder="{{i18n.searchPlaceholder}}" bindinput="onInput" value="{{query}}" /><button class="search-btn" bindtap="doSearch">搜索</button></view><view class="filters"><view class="filter-group"><text class="filter-label">部位:</text><picker bindchange="onBodyPartChange" value="{{bodyPartIndex}}" range="{{bodyParts}}"><view class="picker-item">{{bodyParts[bodyPartIndex]}}</view></picker></view><view class="filter-group"><text class="filter-label">器材:</text><picker bindchange="onEquipmentChange" value="{{equipmentIndex}}" range="{{equipments}}"><view class="picker-item">{{equipments[equipmentIndex]}}</view></picker></view></view><scroll-view class="results" scroll-y wx:if="{{!loading}}"><view wx:if="{{results.length===0}}" class="empty"><text>{{i18n.noResults}}</text></view><block wx:for="{{results}}" wx:key="id"><view class="result-item" bindtap="onSelectExercise" data-id="{{item.id}}"><text class="result-name">{{item.name}}</text><text class="result-info">{{item.body_part}} • {{item.equipment}}</text></view></block></scroll-view></view>