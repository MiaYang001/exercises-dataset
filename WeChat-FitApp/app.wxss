page{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background-color:#f5f5f5;color:#262626}.btn-primary{background-color:#1E90FF;color:#fff;border:none;border-radius:8rpx;padding:16rpx 24rpx;font-size:28rpx;font-weight:500}.btn-primary:active{background-color:#1873CC}.card{background-color:#fff;border-radius:12rpx;padding:16rpx;margin-bottom:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.1)}.text-center{text-align:center}.text-primary{color:#262626}.text-secondary{color:#8c8c8c}.mt-16{margin-top:16rpx}.mb-16{margin-bottom:16rpx}.px-16{padding-left:16rpx;padding-right:16rpx}.flex{display:flex}.flex-center{display:flex;justify-content:center;align-items:center}.flex-between{display:flex;justify-content:space-between;align-items:center}.spinner{width:50rpx;height:50rpx;border:4rpx solid #1E90FF;border-top-color:transparent;border-radius:50%;animation:spin 0.8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}